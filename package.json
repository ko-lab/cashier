{
  "name": "spacier",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "start": "pnpm -r start",
    "dev": "pnpm -r dev --host",
    "build": "pnpm -r build",
    "docker:up": "docker compose -f \"$PWD/infra/docker-compose.yml\" --env-file \"$PWD/infra/.env\" up --build",
    "test": "pnpm -r test",
    "test:be": "pnpm --filter @spacier/backend test",
    "test:fe": "pnpm --filter @spacier/frontend test",
    "hooks:install": "git config core.hooksPath .githooks"
  }
}
