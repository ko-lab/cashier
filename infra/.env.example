# Required for admin export endpoint
ADMIN_PANEL_PASSWORD=change-me

# Frontend payment QR defaults
VITE_IBAN=BE29893944052464
VITE_IBAN_NAME=KO-LAB VZW

# Frontend API URL (Dokploy/prod default)
VITE_API_URL=/rpc

# Optional app version label exposed to the client update checker.
# Set this to commit SHA or build timestamp in CI/CD.
# Optional: set to commit SHA per deploy (workflow/webhook can set COMMIT_SHA)
VITE_APP_VERSION=dev
COMMIT_SHA=

# Optional backend deploy webhook secret (POST /deploy-webhook).
# When called, backend runs `git pull` from its working directory and exits.
# With Docker restart policy enabled, the container comes back up on the new code.
DEPLOY_WEBHOOK_SECRET=change-me
